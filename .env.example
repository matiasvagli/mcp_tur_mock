# ─────────────────────────────────────────────────────────────────────────────
# Turismo MCP Mock API — Variables de entorno
# Copiá este archivo como .env y completá los valores
# ─────────────────────────────────────────────────────────────────────────────

# OBLIGATORIO para el agente IA (/ai/plan-trip y /ai/chat)
# Obtené tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu-clave-aqui

# Opcional: modelo a usar (por defecto gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-2.0-flash

# Opcional: URL base de la API (por defecto localhost:8001)
API_BASE_URL=http://localhost:8001
